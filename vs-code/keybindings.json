// Place your key bindings in this file to override the defaults
[
    {
        "key": "ctrl+alt+c",
        "command": "-latex-workshop.clean",
        "when": "!config.latex-workshop.bind.altKeymap.enabled && !virtualWorkspace && editorLangId =~ /^build$|^latex$|^latex-class$|^latex-package$|^context$|^latex-expl3$|^doctex$|^rsweave$|^jlweave$|^pweave$/"
    },
    {
        "key": "ctrl+alt+c",
        "command": "-debug.copyWatchExpression",
        "when": "watchExpressionsExist && !expressionSelected && focusedView == 'workbench.debug.watchExpressionsView'"
    },
    {
        "key": "shift+alt+q",
        "command": "editor.action.transformToLowercase"
    }
]